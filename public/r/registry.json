{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "hata-ui",
  "homepage": "https://github.com/hatv009/hata-ui",
  "items": [
    {
      "name": "floating-input",
      "title": "Floating Input",
      "description": "Input with label floating",
      "registryDependencies": [
        "field",
        "hatv009/hata-ui/helpers-utilities",
        "input",
        "label"
      ],
      "files": [
        {
          "path": "components/blocks/floating-input.tsx",
          "type": "registry:component",
          "target": "@components/blocks/floating-input.tsx"
        }
      ],
      "type": "registry:block"
    },
    {
      "name": "input",
      "title": "Input",
      "description": "Input UI primitive.",
      "registryDependencies": [
        "hatv009/hata-ui/helpers-utilities"
      ],
      "files": [
        {
          "path": "components/ui/input.tsx",
          "type": "registry:ui",
          "target": "@ui/input.tsx"
        }
      ],
      "type": "registry:ui"
    },
    {
      "name": "agent-rules",
      "description": "Project Nextjs structure, Git, UI, Validate rules.",
      "files": [
        {
          "path": "docs/agent/code-structure.md",
          "type": "registry:file",
          "target": "~/docs/agent/code-structure.md"
        },
        {
          "path": "docs/agent/git.md",
          "type": "registry:file",
          "target": "~/docs/agent/git.md"
        },
        {
          "path": "docs/agent/ui-rules.md",
          "type": "registry:file",
          "target": "~/docs/agent/ui-rules.md"
        },
        {
          "path": "docs/agent/validation.md",
          "type": "registry:file",
          "target": "~/docs/agent/validation.md"
        }
      ],
      "type": "registry:file"
    },
    {
      "name": "project-conventions",
      "title": "Project Conventions",
      "description": "Shared project conventions, editor settings and agent instructions.",
      "files": [
        {
          "path": "AGENTS.md",
          "type": "registry:file",
          "target": "~/AGENTS.md"
        },
        {
          "path": "docs/README.md",
          "type": "registry:file",
          "target": "~/docs/README.md"
        }
      ],
      "type": "registry:item"
    },
    {
      "name": "helpers-utilities",
      "title": "Helpers and Utilities",
      "description": "Shared utility helpers for Hata UI components.",
      "files": [
        {
          "path": "lib/utils.ts",
          "type": "registry:lib",
          "target": "@lib/utils.ts"
        }
      ],
      "type": "registry:lib"
    }
  ]
}